# full method
# full for 1d
import numpy as np 
arr = np.full((2),5)
print(arr)
# full for 2d
import numpy as np 
arr5 = np.full((2,3),5)
print(arr5)
# question --.2d
import numpy as np
arr6 = np.zeros((2,6))
print(arr6+6)
arr7 = np.ones((2,4))
print(arr7 + 5)
# arange for 1d
import numpy as np
arr10 = np.arange(5)
print(arr10)
# arange for 2d
import numpy as np
arr11 = np.arange(0,10,1)
print(arr11)
