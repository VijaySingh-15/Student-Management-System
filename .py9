# comparison
import time
start = time.time()
l = [i*5 for i in range(1000)]
print(l)
print("list output:" ,time.time() - start)
# array
import numpy as np
start = time.time()
arr = np.array(1000)*5
print("array output:", time.time() - start) 
# zeros
import numpy as np
arr_1 = np.zeros((3,4))
print(arr_1)
# ones
arr1 = np.ones((10,10))
print(arr1)
# Question

import numpy as np
arr = np.zeros((2,6))
print(arr + 10)
 
#2d
arr = np.ones((5,6))
