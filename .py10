    # while loop for
import numpy as np
arr1 = np.arange(12).reshape(3,4)
i = 0
len_i = len(arr1)
len_j = len(arr1)
while i < len_i:
    j = 0
    while j < len_j:
        print(arr1[i][j], end=" ")
        j += 1
        i += 1     