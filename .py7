class Withdraw:
  total = 0 # class variable
  def __init__(self,city,state):
    self.city = city
    self.state = state
    Withdraw.total += 1
 
  def location(self):
    print("location")
 
a = Withdraw("jaipur","rajasthan")
 
b = Withdraw("bhilwara","rajasthan")
 
a.total
# over riding
class Address:
    def __init__(self,city,state):
       self.city = city
       self.state = state
    def location(self):
       print("address location")
class User(Address):
    def __init__(self,name,age,city,state):
        super().__init__(city,state)
        self.name = name
        self.age = age
    def location(self):
     print("users locations") 
u = User("arya mains",20,"kukas","rajasthan")
u.location()
