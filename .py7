class Address:
  def __init__(self,city,state):
    self.city = city
    self.state = state
  def location(self):
    print(f"my address location is {self.city} in {self.state}")
 
class HomeTown:
  def __init__(self,city,state):
    self.city = city
    self.state = state
 
  def location(self):
    print(f"my home town location is {self.city} in {self.state}")
  
a = Address("vadodara","gujrat")
a.location()
b = HomeTown("chappra","bihar")
b.location()
