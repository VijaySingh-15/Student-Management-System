 """
class student:
    def __init__(self,args):
        print(type(args))
        print(args)
        self.name = args
        
    def getstu(self):
        return self.name
    
s = student({"name":"hello","age":20})
t = s.getstu()
print(t["age"])
# example 4
class student:
    def __init__(self,*args):
        self.data = args
        
    def users(self):
        for i in self.data[0]:
            print(i)
    def details(self):
        print(self.data[1])
        for i in self.data[1]:
            print()
        
        
s = student(["vijay","shreya","tanmay"],{"address":"kukas","college":"arya","location":"jaipur"})
s.details()
s.users()