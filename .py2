# if elif else 
age = int(input("Enter the number:"))
if age == 18:
    print("your age is :",age)
elif age > 18:
    print("your are above then:",age)
else:
    print("you are less than:",age) """
    # example

marks = int(input("Enter the marks"))
if marks < 60:
    print("fail")
elif marks <= 75:
    print("Grade C")
elif marks <=90:
    print("Grade b")
else: 
    print("grade a")

